# ------------------------------------------------------------------
# SEC / EDGAR
# ------------------------------------------------------------------

# Preferred identity string for EDGAR requests.
EDGAR_USER_AGENT="Your Name your.email@example.com"

# Some existing scripts still read SEC_USER_AGENT directly.
SEC_USER_AGENT="Your Name your.email@example.com"

# Local cache directory for downloaded filing HTML.
EDGAR_DOWNLOAD_DIR=./data/raw

# Delay between EDGAR requests in seconds.
EDGAR_RATE_LIMIT_SLEEP=0.1


# ------------------------------------------------------------------
# Embeddings
# ------------------------------------------------------------------

# Voyage API key used for Finance-2 embeddings in Phase 2.
VOYAGE_API_KEY=

# Default embedding model.
VOYAGE_MODEL=voyage-finance-2


# ------------------------------------------------------------------
# LLM
# ------------------------------------------------------------------

# Provider switch for the extraction layer: openai or ollama.
LLM_PROVIDER=openai

# OpenAI credentials and default model.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama endpoint and model. In Docker full-stack, sec_ollama is the
# network hostname. Override to http://localhost:11434 for host-run Ollama.
OLLAMA_BASE_URL=http://sec_ollama:11434
OLLAMA_MODEL=llama3.1


# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------

# PostgreSQL async URL used by the chunk writer.
DB_URL=postgresql+asyncpg://postgres:password@localhost:5432/sec_rag

# SQLAlchemy async engine pool size.
DB_POOL_SIZE=10


# ------------------------------------------------------------------
# Vector Store
# ------------------------------------------------------------------

# Qdrant HTTP endpoint and collection name.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sec_chunks


# ------------------------------------------------------------------
# App / Retrieval
# ------------------------------------------------------------------

# Runtime mode and logging.
APP_ENV=development
LOG_LEVEL=INFO

# Chunking defaults.
CHUNK_SIZE_TOKENS=600
CHUNK_OVERLAP_TOKENS=100

# Retrieval defaults.
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
