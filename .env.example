# EDGAR / SEC
EDGAR_USER_AGENT="YaNa yashar@example.com"
EDGAR_DOWNLOAD_DIR=./data/raw

# Embeddings
VOYAGE_API_KEY=

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Database
DB_URL=postgresql+asyncpg://postgres:password@localhost:5432/sec_rag
DB_POOL_SIZE=10

# Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sec_chunks

# App
APP_ENV=development
LOG_LEVEL=INFO
CHUNK_SIZE_TOKENS=600
CHUNK_OVERLAP_TOKENS=100
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
